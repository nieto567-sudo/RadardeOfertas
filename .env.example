# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  RadardeOfertas – Configuración de entorno                              ║
# ║                                                                          ║
# ║  Copia este archivo a .env y rellena los valores reales.                ║
# ║  Los valores de DB y Redis usan los nombres de servicio de              ║
# ║  docker-compose (db / redis).  Si ejecutas sin Docker, cámbialos        ║
# ║  a localhost.                                                            ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# docker-compose: usa "db" como host (nombre del servicio)
# Sin Docker:    cambia "db" por "localhost"
DATABASE_URL=postgresql://radar:radar@db:5432/radardeofertas

# ── Redis / Celery ────────────────────────────────────────────────────────────
# docker-compose: usa "redis" como host; sin Docker usa "localhost"
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── Telegram ──────────────────────────────────────────────────────────────────
# Token del bot (obtenlo hablando con @BotFather en Telegram)
TELEGRAM_BOT_TOKEN=TU_TOKEN_AQUI

# Canal PÚBLICO donde el bot publicará las ofertas.
# Formato @username (ej. @mis_ofertas_mx).
# ⚠️ El bot debe ser ADMIN del canal con permiso "Publicar mensajes".
TELEGRAM_CHANNEL_ID=@MI_CANAL_PUBLICO

# Tu chat_id personal para recibir alertas de administrador y errores de precio.
# Averígualo hablando con @userinfobot en Telegram.
TELEGRAM_ADMIN_CHAT_ID=TU_CHAT_ID_AQUI

# IDs de Telegram que pueden ejecutar comandos de admin (/pause, /stats, etc.)
# Separados por coma si hay varios. Usa el mismo ID que TELEGRAM_ADMIN_CHAT_ID.
TELEGRAM_ADMIN_USER_IDS=TU_CHAT_ID_AQUI

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  FILTRO DE PUBLICACIÓN                                                   ║
# ║                                                                          ║
# ║  El bot solo publica en Telegram si la oferta pasa TODOS estos filtros:  ║
# ║  categoría permitida, precio válido, URL válida, sin duplicados en 24h,  ║
# ║  y dentro del límite de rate.                                            ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# Categorías permitidas (lista separada por comas).
# Solo se publican ofertas cuya categoría aparezca aquí.
ALLOWED_CATEGORIES=Celulares y Smartphones,Gaming y Videojuegos,Televisores y Audio,Electrodomésticos,Ropa y Accesorios

# Máximo de publicaciones por día (en el canal de Telegram).
MAX_DAILY_PUBLICATIONS=10

# Máximo de publicaciones en una ventana deslizante de 60 minutos.
MAX_PUBLICATIONS_PER_HOUR=15

# Mínimo de segundos entre publicaciones consecutivas (anti-flood).
MIN_SECONDS_BETWEEN_PUBLICATIONS=5

# Modo prueba: "true" → no envía a Telegram, solo registra logs.
# Ideal para verificar que todo funciona antes del primer arranque real.
DRY_RUN=false

# Archivo JSON donde se guardan las URLs publicadas para deduplicación 24h.
# Por defecto /tmp (funciona en Railway y otros PaaS con filesystem efímero).
# Para mayor persistencia, usa un volumen: /app/data/published_urls.json
# PUBLISHED_URLS_FILE=/app/data/published_urls.json

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  MONETIZACIÓN – Links directos vs. links de afiliado                    ║
# ║                                                                          ║
# ║  Por defecto el bot publica el link directo de la oferta (sin           ║
# ║  afiliados, sin UTM, sin acortador).  Cambia a "true" cuando quieras    ║
# ║  activar la monetización completa.                                       ║
# ╚══════════════════════════════════════════════════════════════════════════╝
MONETIZED_LINKS_ENABLED=false

# ── Detección de ofertas (valores por defecto — descomenta para ajustar) ──────
# PRICE_ERROR_THRESHOLD=0.40       ← precio < 40% del promedio = error de precio
# OFFER_EXCELLENT_THRESHOLD=0.60   ← precio < 60% = oferta excelente
# OFFER_GOOD_THRESHOLD=0.80        ← precio < 80% = buena oferta
# MIN_PUBLISH_SCORE=60             ← score mínimo para publicar (0–100)
# RAPID_DROP_THRESHOLD=0.30        ← % de caída en RAPID_DROP_WINDOW_HOURS
# RAPID_DROP_WINDOW_HOURS=2

# ── Anti-spam ─────────────────────────────────────────────────────────────────
# PUBLICATION_COOLDOWN_HOURS=6     ← horas mínimas entre re-publicar el mismo producto

# ── Calidad mínima de ofertas ─────────────────────────────────────────────────
# MIN_DISCOUNT_PCT=20.0            ← descuento mínimo (%)
# MIN_ABSOLUTE_SAVING_MXN=100.0   ← ahorro mínimo en pesos MXN

# ── Monitoreo de scrapers ─────────────────────────────────────────────────────
# SCRAPER_FAILURE_ALERT_THRESHOLD=3   ← alertas al admin después de N fallos seguidos
# CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# CIRCUIT_BREAKER_COOLDOWN_SECONDS=300

# ── Resumen diario ────────────────────────────────────────────────────────────
# DIGEST_HOUR_UTC=16    ← 16 UTC = 10 AM Ciudad de México
# DIGEST_MINUTE_UTC=0
# DIGEST_TOP_N=10

# ── Horas inteligentes de publicación (hora de México, UTC-6) ────────────────
# SMART_HOURS_ENABLED=true
# SMART_HOURS_MORNING_START=7
# SMART_HOURS_MORNING_END=10
# SMART_HOURS_AFTERNOON_START=12
# SMART_HOURS_AFTERNOON_END=15
# SMART_HOURS_EVENING_START=19
# SMART_HOURS_EVENING_END=23

# ── Deduplicación avanzada ────────────────────────────────────────────────────
# DEDUP_CROSS_STORE=false    ← deduplicar el mismo producto entre distintas tiendas
# REQUIRE_IMAGE=false        ← rechazar productos sin imagen
# MIN_TITLE_LENGTH=10        ← longitud mínima del título del producto

# ── Observabilidad ───────────────────────────────────────────────────────────
# LOG_FORMAT=text            ← "json" para log estructurado (ideal en producción)
# LOG_LEVEL=INFO
# PROMETHEUS_PORT=9090

# ── Schedules de workers (segundos entre ejecuciones) ─────────────────────────
# SCHEDULE_AMAZON_SECONDS=300
# SCHEDULE_MERCADOLIBRE_SECONDS=300
# SCHEDULE_WALMART_SECONDS=600
# SCHEDULE_LIVERPOOL_SECONDS=600
# SCHEDULE_BODEGAAURRERA_SECONDS=600
