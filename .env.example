# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  RadardeOfertas – Configuración de entorno                              ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://radar:radar@localhost:5432/radardeofertas

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel_id_or_numeric_id
# Chat ID (tuyo o de un grupo privado) que recibe alertas de salud del sistema
TELEGRAM_ADMIN_CHAT_ID=your_personal_chat_id

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  MONETIZACIÓN – Habilitación de links de pago                           ║
# ║                                                                          ║
# ║  Por defecto el bot publica el link directo de la oferta (sin           ║
# ║  afiliados, sin UTM, sin acortador).  Cambia a "true" cuando quieras    ║
# ║  activar la monetización completa.                                       ║
# ╚══════════════════════════════════════════════════════════════════════════╝
MONETIZED_LINKS_ENABLED=false

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  MONETIZACIÓN – Programas de afiliados                                  ║
# ║  Con estos tokens el sistema convierte TODOS los links en links de      ║
# ║  afiliado y genera comisiones automáticamente por cada venta.           ║
# ║  Solo se usan cuando MONETIZED_LINKS_ENABLED=true.                      ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── Amazon Associates (4% comisión promedio) ─────────────────────────────────
# Registro: https://associates.amazon.com.mx
# Categorías con mejor comisión: electrónica 4%, moda 10%, libros 4.5%
AMAZON_AFFILIATE_TAG=yourtag-20

# ── MercadoLibre Afiliados (4% comisión promedio) ────────────────────────────
# Registro: https://afiliados.mercadolibre.com
# Paga comisión sobre cualquier producto comprado después de hacer clic en tu link
MERCADOLIBRE_AFFILIATE_ID=your_ml_affiliate_id

# ── AliExpress Portals (6% comisión promedio) ─────────────────────────────────
# Registro: https://portals.aliexpress.com
# Ideal para electrónica y productos chinos
ALIEXPRESS_AFFILIATE_KEY=your_aliexpress_key

# ── eBay Partner Network (2% comisión promedio) ───────────────────────────────
# Registro: https://partnernetwork.ebay.com
EBAY_CAMPAIGN_ID=your_ebay_campaign_id

# ── Admitad (cubre Walmart, Liverpool, Coppel, Costco, Sam's Club y +20 más) ──
# Registro: https://www.admitad.com/en/publisher/
# Cómo obtener los site IDs:
#   1. Crea tu cuenta en Admitad como Publisher
#   2. Ve a "Programmes" y busca cada tienda
#   3. Únete al programa de cada tienda
#   4. En los detalles del programa encontrarás el "Site ID" (ej: "abc123")
#   5. Añade cada ID al dict JSON abajo
#
# Comisiones típicas por tienda en Admitad:
#   Walmart MX:     1-3%    Liverpool:  2-5%
#   Coppel:         2-4%    Costco:     1-3%
#   Sam's Club:     1-3%    Soriana:    1-3%
#   Elektra:        1-3%    Sears:      2-4%
#   Sanborns:       2-4%    Office Depot: 1-3%
#   Cyberpuerta:    2-4%    PCEL:       2-4%
ADMITAD_PUBLISHER_ID=your_admitad_publisher_code
ADMITAD_SITE_IDS={"walmart":"site123","liverpool":"site456","coppel":"site789"}

# ── Bitly (rastreo de clics) ──────────────────────────────────────────────────
# Solo se usa cuando MONETIZED_LINKS_ENABLED=true
# Registro GRATUITO: https://bitly.com  (1,000 links/mes en plan gratuito)
# Con Bitly verás EXACTAMENTE cuántas personas hacen clic en cada oferta
# Cómo configurar:
#   1. Crea cuenta en bitly.com
#   2. Ve a Settings > Developer > Access Tokens
#   3. Genera un token y ponlo aquí
#   4. Opcional: copia tu Group GUID desde la URL de tu dashboard
BITLY_API_TOKEN=your_bitly_token
BITLY_GROUP_GUID=

# ── Parámetros UTM (seguimiento en Google Analytics) ─────────────────────────
# Solo se usan cuando MONETIZED_LINKS_ENABLED=true
# Estos parámetros se agregan AUTOMÁTICAMENTE a todos los links
# Créate una cuenta en analytics.google.com para ver el tráfico que generas
# UTM_SOURCE=radardeofertas   ← identifica que el tráfico viene de tu bot
# UTM_MEDIUM=telegram
# UTM_CAMPAIGN=oferta

# ── Detección de ofertas (opcional – valores por defecto mostrados) ───────────
# PRICE_ERROR_THRESHOLD=0.40       ← precio < 40% del promedio = error de precio
# OFFER_EXCELLENT_THRESHOLD=0.60   ← precio < 60% = oferta excelente
# OFFER_GOOD_THRESHOLD=0.80        ← precio < 80% = buena oferta
# RAPID_DROP_THRESHOLD=0.30
# RAPID_DROP_WINDOW_HOURS=2
# MIN_PUBLISH_SCORE=60

# ── Anti-spam ─────────────────────────────────────────────────────────────────
# PUBLICATION_COOLDOWN_HOURS=6     ← horas mínimas entre publicaciones del mismo producto

# ── Monitoreo de scrapers ─────────────────────────────────────────────────────
# SCRAPER_FAILURE_ALERT_THRESHOLD=3  ← alertas al admin después de N fallos seguidos

# ── Resumen diario ────────────────────────────────────────────────────────────
# DIGEST_HOUR_UTC=16    ← 16 UTC = 10 AM Ciudad de México
# DIGEST_MINUTE_UTC=0
# DIGEST_TOP_N=10

# ── Schedules de workers (segundos entre ejecuciones) ─────────────────────────
# SCHEDULE_AMAZON_SECONDS=300
# SCHEDULE_MERCADOLIBRE_SECONDS=300
# SCHEDULE_WALMART_SECONDS=600
# SCHEDULE_LIVERPOOL_SECONDS=600
# SCHEDULE_BODEGAAURRERA_SECONDS=600
